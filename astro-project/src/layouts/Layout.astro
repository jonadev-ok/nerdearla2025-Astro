---
import Footer from "../components/LayoutComponents/Footer.astro";
import Header from "../components/LayoutComponents/Header.astro";
import "../styles/global.css";
const {
  title = "Astro workshop",
  description = "Bienvenidos a astro | El futuro de las webs estaticas",
  favicon = "../../public/favicon.svg",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
    background: black;
  }
  ,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

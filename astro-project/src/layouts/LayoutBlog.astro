---
import ButtonScroll from "../components/islands/ButtonScroll";
import Footer from "../components/LayoutComponents/Footer.astro";
import HeaderBlog from "../components/LayoutComponents/HeaderBlog.astro";
import "../styles/global.css";
const {
  title = "Astro devs",
  description = "Bienvenidos a Astro devs | El futuro de las webs estaticas",
  favicon = "../../public/logos/AstrodevsFavicon.svg",
} = Astro.props;
const footerDate = {
  text: [
    "Astro devs. un sitio creado por ",
    " - Realizado con 🧡 para",
    "Todos los derechos reservados.",
  ],
  url: ["https://instagram.jona.dev_ok", "https://nerdear.la/es/"],
  Authors: ["Jona Dev", "Nerdearla"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <HeaderBlog />
    <slot />
    <ButtonScroll client:load />
    <Footer {...footerDate} />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
    background: black;
  }
  ,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

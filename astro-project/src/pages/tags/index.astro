---
export const prerender = true;
import LayoutBlog from "../../layouts/LayoutBlog.astro";
const allPosts = await Astro.glob("../content/*.md");
const tags = [
  ...new Set(allPosts.map((post: any) => post.frontmatter.tags).flat()),
];
const pageTitle = "Índice de etiquetas";
---

<LayoutBlog pageTitle={pageTitle}>
  <div class="tags">
    {
      tags.map((tag: any) => (
        <p class="tag">
          <a href={`/tags/${tag.toLowerCase()}`}>{tag}</a>
        </p>
      ))
    }
  </div>
</LayoutBlog>

---
import Hero from "../components/sections/Hero.astro";
import Layout from "../layouts/Layout.astro";
import SectionContainer from "../components/sections/SectionContainer.astro";
const data = {
  title: "Bienvenidos a ",
  span: "Astro Devs",
  description:
    "Una agencia dedicada a ofrecer soluciones web de alto rendimiento para hacer crecer tu negocio.",
  url: "#about",
  cta: "Conoce nuestros servicios",
};
---

<Layout>
  <main role="main">
    <SectionContainer>
      <Hero {...data} />
    </SectionContainer>
  </main>
</Layout>

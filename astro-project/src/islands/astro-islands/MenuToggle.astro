<div class="md:hidden flex justify-end w-full relative px-2 bg-transparent">
  <button
    id="menu-toggle"
    class="text-2xl text-orange-500 flex w-10 h-10 justify-between cursor-pointer"
    aria-label="Abrir menú"
  >
    ☰
  </button>

  <div
    id="menu-content"
    class="absolute right-0 mt-15 text-white shadow p-4 flex flex-col gap-4"
  >
    <a href="#home" class="hover:text-orange-500">Inicio</a>
    <a href="#services" class="hover:text-orange-500">Servicios</a>
    <a href="#contact" class="hover:text-orange-500">Contacto</a>
    <a href="/Blog/" class="hover:text-orange-500">Blog</a>
  </div>

  <script is:inline>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("menu-content");

    toggle.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });

    // Cierra el menú cuando se hace click en un enlace
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
      });
    });
  </script>
</div>

---
const { title, description, link, btnText } = Astro.props;
---

<article
  class="bg-neutral-800 hover:bg-neutral-700 rounded-2xl w-100 overflow-hidden shadow-lg transition flex flex-col mx-2"
>
  <h3 class="text-xl font-semibold text-primary mb-2">{title}</h3>
  <p class="text-gray-600 dark:text-gray-300">
    {description}
  </p>
  <a
    href={link}
    class="inline-block mt-4 text-primary font-bold hover:text-cyan-500 hover:animate-pulse"
    >{btnText}</a
  >
</article>

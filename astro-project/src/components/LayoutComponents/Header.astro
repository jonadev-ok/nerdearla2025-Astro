---
const image = "../../assets/astro.svg";
import MenuToggle from "../../islands/MenuToggle";

const { pathname } = Astro.url;
const itemsNav = [
  {
    title: "Inicio",
    label: "Inicio",
    url: "/",
  },
  {
    title: "Nosotros",
    label: "Nosotros",
    url: "#about",
  },
  {
    title: "Servicios",
    label: "Servicios",
    url: "#services",
  },
  {
    title: "Blog",
    label: "Blog",
    url: "/Blog/",
  },
];
---

<header class="flex w-full items-center justify-between px-4">
  <img
    src="../../../public/favicon.svg"
    class="mx-3 w-10"
    alt="logo"
    loading="lazy"
  />
  <nav class="hidden md:flex gap-6 flex-grow justify-center">
    {
      itemsNav.map((link: any) => {
        const isActive =
          link.url === "/" ? pathname === "/" : pathname.startsWith(link.url);
        return (
          <a
            class={`text-xl ml-15 font-extralight block px-2 py-2 transition transform duration-300 hover:scale-110 ${
              isActive
                ? "text-cyan-500 font-semibold"
                : "text-white hover:text-cyan-500"
            }`}
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        );
      })
    }
  </nav>
  <MenuToggle client:load />
</header>

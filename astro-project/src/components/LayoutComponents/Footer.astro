---
const { text, url, Authors } = Astro.props;
---

<footer
  class="bottom-4 top-4 flex left-0 w-full h-20 justify-center items-center"
>
  <p class="text-center text-xl font-extralight text-gray-200">
    &copy; {new Date().getFullYear()}
    {text[0]}
    <a href={url[0]} target="_blank" class="text-blue-500"
      ><i>{Authors[0]}</i></a
    >
    {text[1]}
    <a href={url[1]} target="_blank" class="text-orange-500"
      ><b>{Authors[1]}</b></a
    >
    {text[2]}
  </p>
</footer>

---
const { title, url, pubDate, tags, description } = Astro.props;
---

<article
  class="bg-neutral-800 hover:bg-neutral-700 rounded-2xl w-100 overflow-hidden shadow-lg transition flex flex-col mx-2"
>
  <div class="p-3 flex flex-col gap-2 ">
    <h2 class="text-2xl font-bold text-white">
      <a href={url} class="hover:underline">
        {title}
      </a>
    </h2>
    <div class="flex flex-wrap gap-3 items-center text-sm text-gray-400">
      📅 {pubDate}
      {
        tags.map((tag: any) => (
          <a
            href={`/tags/${tag}`}
            class="bg-blue-600 text-white px-2 py-1 rounded-md hover:bg-blue-500 transition"
          >
            {tag}
          </a>
        ))
      }
    </div>
    <p class="text-gray-300 line-clamp-3">
      {description}
    </p>
    <a href={url} class="text-blue-500 hover:underline font-medium">
      Leer más →
    </a>
  </div>
</article>
